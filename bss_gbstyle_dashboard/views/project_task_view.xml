<odoo>
    <record id="project_task_form_dashboard_inherit" model="ir.ui.view">
        <field name="name">project.task.form.dashboard.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="bss_gbstyle_main.project_task_form_inherit"/>
        <field name="arch" type="xml">

            <xpath expr="//form/sheet/group/group[2]/div[@id='date_deadline_and_recurring_task']" position="after">
                <field name="dashboard_status" invisible="1"/>
            </xpath>

            <xpath expr="//form/sheet/notebook/page[@name='extra_info']/group/group[2]/field[@name='date_last_stage_update']" position="after">
                <field name="dashboard_status" invisible="1"/>
            </xpath>

        </field>
    </record>
</odoo>